% Geometry
geometry
{
    type FEQuadMesh;
    nex 4;
    ney 4;
    Lx  1;
    Ly  1;
}

% Material
material
{
    type    RigidViscoPlastic;
    m       0.1;
    B       10;
    C       0;
    n       0;
}

% Solution field
solution
{
    name    U;
    nDims   2;
    field   EPSR;
}

% Time controls
runTime
{
    startTime   0;
    endTime     0.1;
    deltaT      0.01;
}

% Numerical solver controls
numerics
{
    alph    1e-2;
    diat    1e+4;
    vscl    5e-4;
}